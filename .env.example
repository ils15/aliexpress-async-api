# AliExpress API Credentials
# Get these from the AliExpress Open Platform (https://developers.aliexpress.com/)
APP_KEY=your_app_key_here
APP_SECRET=your_app_secret_here
TRACKING_ID=your_tracking_id_here

# PyPI Authentication Token
# Obtain this token from your PyPI account settings (https://pypi.org/manage/account/token/)
# It should start with "pypi-"
PYPI_TOKEN=pypi-your_pypi_token_here

# Optional: TestPyPI Token for testing releases before publishing to the main index
# https://test.pypi.org/manage/account/token/
TEST_PYPI_TOKEN=pypi-your_test_pypi_token_here
